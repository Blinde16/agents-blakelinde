# ==========================================
# Blake Linde Agents Platform - Local Environment Setup
# ==========================================

# ------------------------------------------
# 1. SHARED SECRETS (Must match exactly in both environments)
# ------------------------------------------
# Used by Next.js to authenticate requests to the Python FastAPI backend.
# Generate a random secure string for production (e.g. `openssl rand -hex 32`)
INTERNAL_SERVICE_KEY_SIGNER=dev_service_token_123

# ------------------------------------------
# 2. FRONTEND (Next.js `/web`)
# ------------------------------------------
# Point Next.js API routes to the local Python FastAPI instance
BACKEND_API_URL=http://127.0.0.1:8000

# (Placeholder) Clerk Authentication Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ------------------------------------------
# 3. BACKEND (Python `/agent`)
# ------------------------------------------
# Supabase Postgres Connection String
# Required format: postgresql://[user]:[password]@[host]:5432/[db]
# Used by Agno PgMemoryDb to store state
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# OpenAI API Key (Required for gpt-4o and gpt-4o-mini execution)
OPENAI_API_KEY=sk-...

# Agno Tracing (Recommended for debugging the agent flow)
AGNO_API_KEY=agno_...

# Integration Tools (Used by Functional Layers)
HUBSPOT_API_KEY=pat-...
NOTION_API_KEY=secret_...
