# ==========================================
# Blake Linde Agents Platform — environment template
# ==========================================
#
# Where to put values:
# - Shared (Next BFF + FastAPI): same value in root `.env`, `web/.env`, and `agent/.env` if you use copies.
# - `web/.env` only: Clerk publishable key, BACKEND_API_URL, INTERNAL_SERVICE_KEY_SIGNER. Do NOT put DATABASE_URL
#   or OPENAI_API_KEY in the Next layer unless you have a specific need — keep DB/LLM secrets on the Python service.
# - `agent/.env` only: DATABASE_URL, OPENAI_API_KEY, CLERK_JWT_ISSUER, integration tokens, SECRETS_FERNET_KEY.
#
# ------------------------------------------
# 1. SHARED — must match between Next API routes and FastAPI
# ------------------------------------------
INTERNAL_SERVICE_KEY_SIGNER=dev_service_token_123

# ------------------------------------------
# 2. FRONTEND (`web/.env`)
# ------------------------------------------
BACKEND_API_URL=http://127.0.0.1:8000

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ------------------------------------------
# 3. BACKEND (`agent/.env`)
# ------------------------------------------
# Supabase / Postgres (pooler URL ok)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

OPENAI_API_KEY=sk-...

# Clerk JWT validation (Frontend API / issuer URL from Clerk dashboard)
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev

# Optional: LLM intent router (default on when OPENAI_API_KEY is set)
# ROUTER_USE_LLM=1
# OPENAI_ROUTER_MODEL=gpt-4o-mini

AGNO_API_KEY=agno_...

# Integration secrets — encrypt at rest when SECRETS_FERNET_KEY is set (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SECRETS_FERNET_KEY=
# Local dev only: store integration tokens without Fernet (not for production)
# ALLOW_PLAINTEXT_INTEGRATION_SECRETS=1

# HubSpot (private app token preferred; HUBSPOT_API_KEY also accepted for legacy .env files)
HUBSPOT_PRIVATE_APP_TOKEN=pat-...
# HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_API_KEY=

NOTION_API_KEY=secret_...

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
