# Shared / core
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
INTERNAL_SERVICE_KEY_SIGNER=replace_with_long_random_shared_secret

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# Backend LLMs
OPENAI_API_KEY=sk-replace_me
OPENAI_MODEL=gpt-4o-mini
OPENAI_ROUTER_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ROUTER_USE_LLM=1

# Runtime / logging
LOG_LEVEL=INFO
THREAD_RUN_STALE_SECONDS=480
PG_POOL_MIN=1
PG_POOL_MAX=12
PG_POOL_COMMAND_TIMEOUT=120
TOOL_SYNC_TIMEOUT=120

# Integration secret storage
SECRETS_FERNET_KEY=replace_with_fernet_key

# Optional integrations
HUBSPOT_PRIVATE_APP_TOKEN=
NOTION_API_KEY=
NOTION_CONTENT_CALENDAR_DB_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PRIMARY_CALENDAR_ID=primary

# Local-only dev toggles; do not use in production
ALLOW_INSECURE_DEV_AUTH=0
DEV_CLERK_USER_ID=
ALLOW_PLAINTEXT_INTEGRATION_SECRETS=0
